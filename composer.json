{
  "name": "watsonhaw/think-migration",
  "description": "ThinkPHP 8 数据库迁移扩展：基于 phinx 提供迁移 (migrate)、回滚、数据填充 (seeder) 与模型工厂 (factory) 功能，支持通过 think 命令管理数据库结构变更。",
  "type": "think-extend",
  "keywords": [
    "thinkphp",
    "thinkphp8",
    "migration",
    "phinx",
    "seeder",
    "factory",
    "database"
  ],
  "homepage": "https://doc.thinkphp.cn/v8_0/think-migration.html",
  "authors": [
    {
      "name": "yunwuxin",
      "email": "448901948@qq.com"
    },
    {
      "name": "watsonhaw",
      "email": "watsonhaw@hotmail.com"
    }
  ],
  "license": "Apache-2.0",
  "autoload": {
    "psr-4": {
      "think\\migration\\": "src"
    },
    "files": [
      "src/helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "think\\migration\\Tests\\": "tests"
    }
  },
  "require": {
    "php": ">=8.0",
    "robmorgan/phinx": "^0.16.0",
    "topthink/framework": "^8.0",
    "topthink/think-helper": "^3.0.3"
  },
  "require-dev": {
    "composer/composer": "^2.5.8",
    "fakerphp/faker": "^1.20",
    "phpunit/phpunit": "^10.0"
  },
  "config": {
    "sort-packages": true
  },
  "suggest": {
    "fakerphp/faker": "Required to use the factory builder (^1.20)."
  },
  "scripts": {
    "test": "phpunit",
    "lint": "mago lint",
    "format": "mago format",
    "analyze": "mago analyze"
  },
  "extra": {
    "think": {
      "services": [
        "think\\migration\\Service"
      ]
    }
  }
}