{
  "name": "topthink/think-migration",
  "authors": [
    {
      "name": "yunwuxin",
      "email": "448901948@qq.com"
    }
  ],
  "license": "Apache-2.0",
  "autoload": {
    "psr-4": {
      "Phinx\\": "phinx",
      "think\\migration\\": "src"
    }
  },
  "require": {
    "php": ">=8.0",
    "robmorgan/phinx": "^0.13.4",
    "symfony/filesystem": "^5.4 || ^6.0",
    "symfony/finder": "^5.4 || ^6.0",
    "topthink/framework": "^8.0",
    "topthink/think-helper": "^3.0.3"
  },
  "require-dev": {
    "composer/composer": "^2.5.8",
    "fakerphp/faker": "^1.20"
  },
  "config": {
    "sort-packages": true
  },
  "suggest": {
    "fakerphp/faker": "Required to use the factory builder (^1.20)."
  },
  "scripts": {
    "lint": "mago lint",
    "format": "mago format",
    "analyze": "mago analyze",
    "post-install-cmd": [
      "think\\migration\\UsePhinx::run"
    ],
    "post-update-cmd": [
      "think\\migration\\UsePhinx::run"
    ]
  },
  "extra": {
    "think": {
      "services": [
        "think\\migration\\Service"
      ]
    }
  }
}